{
  "info": {
    "name": "Trace Notify Engine",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "notificationId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"USER\"\n}" }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"secret123\"\n}" }
      }
    },
    {
      "name": "Notifications - Send",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/notifications/send",
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Order placed\",\n  \"message\": \"Your order #42 is confirmed\",\n  \"type\": \"ORDER_PLACED\",\n  \"priority\": \"HIGH\",\n  \"serviceName\": \"OrderService\"\n}" }
      }
    },
    {
      "name": "Notifications - My History",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/notifications/me?page=0&size=10"
      }
    },
    {
      "name": "Notifications - Mark Read",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/notifications/{{notificationId}}/read"
      }
    },
    {
      "name": "Notifications - Delete",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/notifications/{{notificationId}}"
      }
    },
    {
      "name": "Causality - Trace",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/notifications/{{notificationId}}/trace"
      }
    },
    {
      "name": "Preferences - Get",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/preferences"
      }
    },
    {
      "name": "Preferences - Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/preferences",
        "body": { "mode": "raw", "raw": "{\n  \"inAppEnabled\": false\n}" }
      }
    },
    {
      "name": "Contracts - Register (Admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/contracts/register",
        "body": { "mode": "raw", "raw": "{\n  \"serviceName\": \"OrderService\",\n  \"allowedEventTypes\": [\"ORDER_PLACED\", \"ORDER_CANCELLED\"],\n  \"maxFrequencyPerMinute\": 60,\n  \"priorityLevel\": \"HIGH\"\n}" }
      }
    },
    {
      "name": "Contracts - List (Admin)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/contracts"
      }
    },
    {
      "name": "Contracts - Violations (Admin)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/contracts/violations"
      }
    },
    {
      "name": "Admin - DLQ",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/admin/dlq"
      }
    },
    {
      "name": "Admin - Violations",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/admin/violations"
      }
    }
  ]
}
