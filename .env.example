# Copy to .env and adjust. Do NOT commit the real .env.
SERVER_PORT=8080
DB_URL=jdbc:postgresql://postgres:5432/tracenotify
DB_USERNAME=tracenotify
DB_PASSWORD=tracenotify
POSTGRES_DB=tracenotify
POSTGRES_USER=tracenotify
POSTGRES_PASSWORD=tracenotify
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=trace-notify
JWT_SECRET=change-me-to-a-long-random-secret-at-least-256-bits-long-value
JWT_EXPIRATION_MS=86400000
